#!/usr/bin/env python3
import argparse
import asyncio
import json
import logging
import logging.handlers
import os
import sys
import tempfile
import traceback
from pathlib import Path
from typing import Any, Dict, List

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from acdhQos.backend import *
from acdhQos.cluster import *
from acdhQos.redmine_helpers import format_container_description_textile
from checks import check_acdh_logo, check_helpdesk_email, check_accessibility, check_imprint_page
from config import config as app_config
from utils.http_client import ResilientHttpClient

parser = argparse.ArgumentParser()
parser.add_argument('--redmineUrl', default='https://redmine.acdh.oeaw.ac.at/')
parser.add_argument('--redmineUser', default='qosScript')
parser.add_argument('--redminePswd', default=os.getenv('REDMINE_PSWD'))
parser.add_argument('--redmineLogIssueId', default=18419)
parser.add_argument('--rancherUrl', default='https://rancher.acdh-dev.oeaw.ac.at/v3')
parser.add_argument('--rancherToken', default=os.getenv('RANCHER_TOKEN'))
parser.add_argument('--rancherProject', help='limits Rancher processing to a single project of a given name')
parser.add_argument('--rancherSkipProjects', nargs='*', help='excludes a given Rancher project(s) from processing')
parser.add_argument('--rancherSkipClusters', nargs='*', help='excludes a given Rancher cluster(s) from processing')
parser.add_argument('--rancherSkipTypes', nargs='*', choices=['deployment', 'cronJob', 'daemonSet', 'job', 'statefulSet'], default=['cronJob', 'job'], help='excludes a given type of Rancher workloads')
parser.add_argument('--rancher', action='store_true', help='process Rancher')
parser.add_argument('--verbose', action='store_true')
parser.add_argument('--readOnly', action='store_true', help='Only read data and do not update the backend')
args = parser.parse_args()

logging.basicConfig(level=logging.DEBUG if args.verbose else logging.INFO)
logger = logging.getLogger()

# file log which will be stored in the `args.redmineLogIssueId` issue description
(fh, logPath) = tempfile.mkstemp()
os.close(fh)
lh2 = logging.FileHandler(logPath)
lh2.setLevel(logging.WARNING)
lh2.setFormatter(logging.Formatter('#%(levelname)s: %(message)s'))
logger.addHandler(lh2)


def format_checks_for_redmine(checks: List[Dict[str, Any]]) -> str:
    """Format check results as a Redmine textile table."""
    lines = ["|_. Check |_. Status |_. Details |"]
    for c in checks:
        status_icon = {
            "PASS": "✅",
            "FAIL": "❌",
            "WARN": "⚠️",
            "ERROR": "🔧",
        }.get(c.get("status"), "❓")

        details = c.get("details", "")
        if c.get("issues"):
            details += "\n" + "\n".join(f"* {i}" for i in c["issues"])

        lines.append(f"| {c['check']} | {status_icon} {c.get('status', 'UNKNOWN')} | {details} |")
    return "\n".join(lines)


async def run_all_checks(endpoint_url: str, http_client: ResilientHttpClient) -> List[Dict[str, Any]]:
    response = await http_client.get(endpoint_url)

    if response["skipped"]:
        return [{
            "check": "All",
            "status": "SKIP",
            "details": f"Skipped: {response['error']}",
        }]

    if response["error"] or response["status"] >= 400:
        error_detail = response["error"] or f"HTTP {response['status']}"
        return [{
            "check": "Reachability",
            "status": "FAIL",
            "details": error_detail,
        }]

    html = response["text"]

    return [
        check_acdh_logo(html=html, url=endpoint_url),
        check_helpdesk_email(html=html),
        await check_imprint_page(html=html, url=endpoint_url, http_client=http_client),
        check_accessibility(html=html, url=endpoint_url),
    ]


async def main_async(data: List[Dict[str, Any]], backend: Any = None) -> None:
    async with ResilientHttpClient(
        requests_per_second=app_config["http"]["requests_per_second"],
        max_concurrent=app_config["http"]["max_concurrent"],
        timeout_seconds=app_config["http"]["timeout_seconds"],
        max_retries=app_config["http"]["max_retries"],
    ) as http_client:
        if not args.readOnly:
            logging.info('Updating backend with the gathered data')

        for i in data:
            try:
                checks: List[Dict[str, Any]] = []
                if i.get('endpoint'):
                    checks = await run_all_checks(i['endpoint'], http_client)
                    checks_table = format_checks_for_redmine(checks)
                    logging.info('[%s] QoS checks:\n%s', i.get('server'), checks_table)

                if not args.readOnly and backend is not None:
                    record = backend.findRecord(i)
                    record.update(i)

            except RecordNotFound:
                logging.error('[%s] Backend record not found for: %s', i.get('server'), format_container_description_textile(i))
            except RecordDuplicated as e:
                logging.error(
                    '[%s] Backend record %s duplication between: %s and %s',
                    i.get('server'),
                    str(e.id),
                    format_container_description_textile(e.newData),
                    format_container_description_textile(e.oldData),
                )
            except RecordError as e:
                logging.error('[%s] %s', i.get('server'), str(e))
            except Exception:
                logging.error(traceback.format_exc())


if not args.readOnly:
    backend = Redmine(args.redmineUrl, (args.redmineUser, args.redminePswd), logIssueId=args.redmineLogIssueId)
    backend.begin()
    logging.info('Backend initialization successful')
else:
    backend = None

procServers: List[str] = []
try:
    data: List[Dict[str, Any]] = []
    if args.rancher:
        try:
            r = Rancher(
                args.rancherUrl,
                args.rancherToken,
                args.rancherProject,
                args.rancherSkipProjects,
                args.rancherSkipClusters,
                args.rancherSkipTypes,
            )
            data += r.harvest()
            procServers += r.getClusters()
        except Exception:
            logging.error('[%s] %s', args.rancherUrl, traceback.format_exc())

    if args.readOnly:
        logging.info('Listing harvested data')
    else:
        logging.info('Updating backend with the gathered data')

    asyncio.run(main_async(data, backend))

    if args.readOnly:
        for i in data:
            logging.info(json.dumps(i))
except Exception:
    logging.error(traceback.format_exc())
finally:
    if not args.readOnly and backend is not None:
        with open(logPath) as fd:
            backend.end(fd.read(), procServers)
    os.unlink(logPath)

